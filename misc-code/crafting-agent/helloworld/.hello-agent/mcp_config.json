{
  "servers": [
    {
      "name": "tavily-mcp",
      "server_url": "https://mcp.tavily.com/mcp/",
      "headers": {
        "Authorization": "${TAVILY_API_KEY}"
      }
    },
    {
      "name": "playwright-mcp",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "enabled": false
    }
  ]
}
